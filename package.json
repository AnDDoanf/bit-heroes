{
  "name": "bit-heroes-familiars",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/sync-public-assets.mjs && next build && node scripts/finalize-export.mjs",
    "start": "next start",
    "predeploy": "cross-env BASE_PATH=/bit-heroes npm run build",
    "deploy": "gh-pages -d out",
    "extract": "node scripts/extract-data.mjs",
    "download:assets": "node scripts/download-assets.mjs",
    "prepare:data": "npm run extract && npm run download:assets"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "gh-pages": "^5.0.0"
  },
  "dependencies": {
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
